# OpenAI
OPENAI_API_KEY=
OPENAI_PARSER_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Supabase (server-side / service-role)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (client-side / public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_MEDIA_BUCKET=habit-media

# App URL (set to your Vercel domain in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (email reminders — optional)
RESEND_API_KEY=
REMINDER_FROM_EMAIL=

# Cron secret (used to authenticate /api/cron/reminders)
REMINDER_CRON_SECRET=

# Web Push (VAPID keys — generate with: npx web-push generate-vapid-keys)
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Timezone for reminder matching
REMINDER_TIMEZONE=Asia/Kolkata
